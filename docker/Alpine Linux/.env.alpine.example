# Sakura AI - Alpine Linux Docker 环境变量配置
# 复制此文件为 .env 并填写实际值

# ==================== 数据库配置 ====================
MYSQL_ROOT_PASSWORD=your_mysql_root_password_here
DB_PASSWORD=your_sakura_ai_db_password_here

# ==================== 应用配置 ====================
JWT_SECRET=your_random_jwt_secret_key_change_this_in_production

# ==================== AI 配置 ====================
# OpenRouter API Key（必需）
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 默认 AI 模型
DEFAULT_MODEL=openai/gpt-4o

# ==================== RAG 配置（可选）====================
# Qdrant 向量数据库 URL
QDRANT_URL=http://qdrant:6333

# 嵌入模型提供商（aliyun 或 openai）
EMBEDDING_PROVIDER=aliyun

# 阿里云 Embedding API Key
EMBEDDING_API_KEY=your_aliyun_embedding_api_key_here
