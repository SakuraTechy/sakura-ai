# ============================================
# Sakura AI 环境配置文件
# ============================================
# 说明：
# - 本文件包含应用运行时的所有配置
# - Docker 镜像构建配置请查看: docker/Debian Linux/config.sh
# - 复制此文件为 .env 并修改相应的值
# ============================================

# ========== 数据库配置 ==========
# 使用 Docker 默认数据库，配置root密码和sakura_ai密码即可
MYSQL_ROOT_PASSWORD=your_mysql_root_password_here
DB_PASSWORD=your_sakura_ai_db_password_here

# 使用指定数据库，可配置任意mysql数据库
DATABASE_URL=mysql://root:your_mysql_root_password_here@localhost:3306/sakura_ai
# DATABASE_URL=mysql://sakura_ai:your_sakura_ai_db_password_here@localhost:3306/sakura_ai
# DATABASE_URL=mysql://root:7PhaaEL3REbCabRb@172.19.5.222:3306/sakura_ai

# ========== 应用配置 ==========
NODE_ENV=development               # 环境: development / production
VITE_PORT=5173                     # 前端端口
PORT=3001                          # 后端端口
SERVER_HOST=0.0.0.0                # 监听所有网络接口（推荐）
# SERVER_HOST=127.0.0.1              # 仅本地访问（安全限制）

# 🔥 证据服务基础URL（可选，留空则自动从请求头获取）
# 如需固定URL（如反向代理场景），可手动设置: http://your-domain.com
# BASE_URL=

# ========== JWT 认证 ==========
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d                  # Token 过期时间

# ========== Playwright 配置 ==========
PLAYWRIGHT_HEADLESS=true           # 无头模式: true / false
PLAYWRIGHT_BROWSER=chromium        # 浏览器: chromium / firefox / webkit

# ========== 测试执行配置 ==========
TEST_TIMEOUT=600000                # 测试超时: 10 分钟
MAX_CONCURRENT_TESTS=6             # 最大并发数

# ========== MCP 浏览器配置 ==========
MCP_BROWSER_FULLSCREEN=true        # MCP模式浏览器全屏: true / false (默认: true)
MCP_BROWSER_MAXIMIZED=true         # MCP模式浏览器最大化: true / false (默认: true)
MCP_BROWSER_WINDOW_SIZE=1920,1080  # MCP模式浏览器窗口大小 (默认: 1920,1080)

# 🚀 Phase 7: 浏览器预安装优化 - 设为false可跳过预安装检查，提升启动速度
PLAYWRIGHT_PRE_INSTALL_BROWSER=true

# 🤖 AI服务配置 (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=openai/gpt-4o
DEFAULT_TEMPERATURE=0.3
DEFAULT_MAX_TOKENS=4000

# 🤖 本地 Gemini API 配置（可选）
# 用于本地部署的 Gemini 2.5 Flash 模型，支持文本、图片、音频多模态输入
GEMINI_LOCAL_BASE_URL=http://localhost:3000/v1
GEMINI_LOCAL_API_KEY=your_local_api_key_here

# 安全提示：
# - 将 GEMINI_LOCAL_API_KEY 替换为实际的认证密钥
# - 生产环境请使用强密码，避免使用默认值（如 "123456"）
# - .env 文件已在 .gitignore 中排除，不会提交到版本控制
# - 本地 API 服务需先启动（默认端口 3000）

# 🌐 代理配置（用于访问国外 API）
# HTTP_PROXY=http://127.0.0.1:10808
# HTTPS_PROXY=http://127.0.0.1:10808
HTTP_PROXY=
HTTPS_PROXY=

# ========== Qdrant向量数据库知识库配置 ==========
# http://172.19.5.227:6333/dashboard#/welcome
QDRANT_URL=http://172.19.5.227:6333

# Embedding提供商选择: gemini, openai, 或 aliyun（推荐国内用户）
EMBEDDING_PROVIDER=aliyun

# 方案1：阿里云通义千问 Embedding（国内推荐！）
# 获取API Key: https://dashscope.console.aliyun.com/apiKey
EMBEDDING_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=sk-xxxxx
EMBEDDING_MODEL=text-embedding-v4

# 方案2：Google Gemini Embedding（完全免费，需代理）
# EMBEDDING_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here

# 方案3：OpenAI Embedding（如果有API Key）
# EMBEDDING_PROVIDER=openai
# EMBEDDING_API_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=your_openai_api_key_here
# EMBEDDING_MODEL=text-embedding-3-small

# ========== 日志配置 ==========
LOG_LEVEL=info                     # 日志级别: debug / info / warn / error
LOG_FULL_PROMPT=false              # 是否记录完整 AI Prompt
LOG_FILE_PATH=logs/ai.log
LOG_MAX_SIZE=50M
LOG_MAX_FILES=5